# MongoDB Atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/safestay?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long

# Server
PORT=5000
NODE_ENV=development

# Cloudinary (Image & Document Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email (Gmail SMTP for OTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173

# AI APIs
GROQ_API_KEY=your_groq_api_key
MISTRAL_API_KEY=your_mistral_api_key
GEMINI_API_KEY=your_gemini_api_key

# Sarvam AI (Translation — Indian languages)
SARVAM_API_KEY=your_sarvam_api_key

# ElevenLabs (Voice synthesis)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Demo Mode (set to 'true' to skip external API calls)
DEMO_MODE=false

# Admin Creation
ADMIN_MASTER_KEY=your_super_secret_master_key_12345
